# ─── Backend ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://switchback:switchback@localhost:5432/switchback
# Needed only to (re)build the literature corpus or use the live /api/literature
# ingest path. `make seed` replays the committed corpus offline without it.
ANTHROPIC_API_KEY=sk-ant-...

# Model routing (config-driven — never hard-code a model id in a module)
MODEL_EXTRACT=claude-sonnet-5
MODEL_REASON=claude-opus-4-8
EMBEDDING_DIM=1024

# External data sources (public)
EUROPEPMC_BASE=https://www.ebi.ac.uk/europepmc/webservices/rest
CARD_BASE=https://card.mcmaster.ca
# CARD's ARO ontology is queried via EBI OLS for grounding accessions.
OLS_BASE=https://www.ebi.ac.uk/ols4/api
UNIPROT_BASE=https://rest.uniprot.org
BVBRC_BASE=https://www.bv-brc.org/api
NCBI_EUTILS_BASE=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# Tamarind Bio — AlphaFold structure prediction (AI/ML). Auth via x-api-key.
TAMARIND_API_KEY=
TAMARIND_BASE=https://app.tamarind.bio/api/

# Optional: regenerate the demo snapshot from a local BurkData tree.
# BURKDATA_DIR=/path/to/BurkData

# ─── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
